# Your xCloud Personal Access Token (PAT).
# Mint at app.xcloud.host -> Account -> API Tokens; the value is shown once.
# Scope it narrowly (e.g. read:servers) — the token is the real safety boundary.
XCLOUD_API_TOKEN=

# Optional: fetch the PAT from your own secret store instead of the plaintext var above.
# Set this to a command that prints the token to stdout; it is run once at startup via
# execFile (no shell), and takes precedence over XCLOUD_API_TOKEN. Examples:
#   XCLOUD_TOKEN_CMD=gopass show company/xcloud/pat
#   XCLOUD_TOKEN_CMD=op read op://Private/xcloud/token          # 1Password
#   XCLOUD_TOKEN_CMD=security find-generic-password -w -s xcloud-pat   # macOS Keychain
# XCLOUD_TOKEN_CMD=

# Optional: override the xCloud API base URL.
# Defaults to https://app.xcloud.host/api/v1
# XCLOUD_API_BASE=

# Destructive ops (reboot_server, restart_service, delete_firewall_rule, delete_cron_job)
# are HIDDEN by default. Set this to exactly "true" to expose them; they still need a
# write-scoped PAT and ask for confirmation at call time. (ADR-0004)
# XCLOUD_ENABLE_DESTRUCTIVE=true

# By default a destructive op fails closed when the agent harness offers no confirmation
# channel. Set this to exactly "true" to waive the prompt and run destructive ops
# unattended (e.g. CI / headless) — you accept the risk. Only meaningful with the flag above.
# XCLOUD_DESTRUCTIVE_NO_CONFIRM=true
